# Intuition network configuration
# Mainnet: chain 1155, Testnet: chain 13579
VITE_CHAIN_ID=13579

# RPC endpoint for the selected chain
# Mainnet: https://rpc.intuition.systems/http
# Testnet: https://testnet.rpc.intuition.systems/http
VITE_RPC_URL=https://testnet.rpc.intuition.systems/http

# GraphQL indexer for atom/triple/position discovery
# Mainnet: https://mainnet.intuition.sh/v1/graphql
# Testnet: https://testnet.intuition.sh/v1/graphql
VITE_GRAPHQL_URL=https://testnet.intuition.sh/v1/graphql

# MultiVault contract address
# Mainnet: 0x6E35cF57A41fA15eA0EaE9C33e751b01A784Fe7e
# Testnet: 0x2Ece8D4dEdcB9918A398528f3fa4688b1d2CAB91
VITE_MULTIVAULT_ADDRESS=0x2Ece8D4dEdcB9918A398528f3fa4688b1d2CAB91
